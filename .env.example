# Copier vers .env et renseigner vos valeurs (Oracle SQL Developer utilise les mêmes identifiants)
# Schéma Oracle : sql/01_installation/01_grants.sql puis sql/01_installation/02_database.sql (voir sql/README.md)

ORACLE_USER=rdv_app
ORACLE_PASSWORD=rdv123

# Mode "thin" (sans client Oracle installé) : Easy Connect
# Exemple : localhost:1521/XEPDB1  (Oracle XE 21c, PDB par défaut souvent XEPDB1)
ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# Flask — sessions (cookies) pour /api/auth/login ; à changer en production
SECRET_KEY=changez-moi-en-production

# Origines autorisées pour CORS (front Vite), séparées par des virgules
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Frontend (fichier frontend/.env ou frontend/.env.local) ---
# URL de l’API Flask (même machine : port 5000 par défaut)
# VITE_API_URL=http://127.0.0.1:5000
